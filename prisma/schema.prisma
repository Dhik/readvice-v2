// ─── Ads Monitoring (targets vs actuals by channel/day) ──────────────────────

model AdsMonitoring {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @map("tenant_id")
  date           DateTime @db.Date
  channel        String

  gmvTarget      Decimal? @db.Decimal(15, 2) @map("gmv_target")
  gmvActual      Decimal? @db.Decimal(15, 2) @map("gmv_actual")
  spentTarget    Decimal? @db.Decimal(15, 2) @map("spent_target")
  spentActual    Decimal? @db.Decimal(15, 2) @map("spent_actual")
  roasTarget     Decimal? @db.Decimal(8, 4)  @map("roas_target")
  roasActual     Decimal? @db.Decimal(8, 4)  @map("roas_actual")
  cpaTarget      Decimal? @db.Decimal(15, 2) @map("cpa_target")
  cpaActual      Decimal? @db.Decimal(15, 2) @map("cpa_actual")
  aovToCpaTarget Decimal? @db.Decimal(8, 4)  @map("aov_to_cpa_target")
  aovToCpaActual Decimal? @db.Decimal(8, 4)  @map("aov_to_cpa_actual")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt     @map("updated_at")

  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date, channel])
  @@index([tenantId, date])
  @@index([channel])
  @@map("ads_monitoring")
}

// ─── AI chat (AI-2) ─────────────────────────────────────
model AiConversation {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  userId    Int      @map("user_id")
  title     String
  summary   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  messages AiMessage[]

  @@index([tenantId, userId])
  @@map("ai_conversations")
}

model AiMessage {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  role           String
  content        String   @db.Text
  inputTokens    Int?     @map("input_tokens")
  outputTokens   Int?     @map("output_tokens")
  chart          Json?                            // persisted Chart.js spec (already validated)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

// ─── Data Connectors (generic Google Sheets sync) ────────

model DataConnector {
  id             Int       @id @default(autoincrement())
  tenantId       Int       @map("tenant_id")
  name           String
  connectorType  String    @map("connector_type")   // order_sync | ad_spend_sync | visit_sync | netprofit_sync
  spreadsheetId  String    @map("spreadsheet_id")
  sheetTab       String    @map("sheet_tab")
  dataRange      String    @map("data_range")
  targetTable    String    @map("target_table")
  upsertKey      Json      @map("upsert_key")
  columnMapping  Json      @map("column_mapping")
  staticValues   Json?     @map("static_values")
  isActive       Boolean   @default(true) @map("is_active")
  lastSyncAt     DateTime? @map("last_sync_at")
  lastSyncResult Json?     @map("last_sync_result")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId, connectorType])
  @@map("data_connectors")
}

// ─── Subscriptions & Billing ─────────────────────────────

model Plan {
  id             Int      @id @default(autoincrement())
  name           String
  slug           String   @unique
  priceMonthly   Decimal  @db.Decimal(15, 2) @map("price_monthly")
  currency       String   @default("IDR")
  maxUsers       Int?     @map("max_users")
  maxTenants     Int?     @map("max_tenants")
  hasAi          Boolean  @default(false) @map("has_ai")
  aiQuotaMonthly Int?     @map("ai_quota_monthly")
  hasPdfExports  Boolean  @default(false) @map("has_pdf_exports")
  hasMultiTenant Boolean  @default(false) @map("has_multi_tenant")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  subscriptions  Subscription[]
  paymentRecords PaymentRecord[]

  @@map("plans")
}

model Subscription {
  id                 Int       @id @default(autoincrement())
  tenantId           Int       @unique @map("tenant_id")
  planId             Int       @map("plan_id")
  status             String
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  gracePeriodEnd     DateTime? @map("grace_period_end")
  cancelledAt        DateTime? @map("cancelled_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan           Plan            @relation(fields: [planId], references: [id])
  paymentRecords PaymentRecord[]

  @@index([status])
  @@map("subscriptions")
}

model PaymentRecord {
  id                    Int       @id @default(autoincrement())
  tenantId              Int       @map("tenant_id")
  subscriptionId        Int       @map("subscription_id")
  midtransOrderId       String    @unique @map("midtrans_order_id")
  midtransTransactionId String?   @map("midtrans_transaction_id")
  amount                Decimal   @db.Decimal(15, 2)
  currency              String    @default("IDR")
  status                String
  planId                Int       @map("plan_id")
  periodMonths          Int       @default(1) @map("period_months")
  paidAt                DateTime? @map("paid_at")
  snapToken             String?   @map("snap_token")
  snapUrl               String?   @map("snap_url")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([tenantId, status])
  @@index([subscriptionId])
  @@map("payment_records")
}
